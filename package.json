{
  "name": "fru-selector",
  "version": "1.0.0",
  "description": "Surface Device Part Finder - Find the right FRU parts for Surface device repairs",
  "main": "dist/main/index.js",
  "homepage": "./",
  "author": "Microsoft",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:main && npm run build:react",
    "build:react": "react-scripts build",
    "build:main": "tsc --project tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "dev": "concurrently \"npm run react-dev\" \"npm run main-dev\"",
    "react-dev": "react-scripts start",
    "main-dev": "wait-on http://localhost:3000 && tsc --project tsconfig.main.json --watch --preserveWatchOutput & electron .",
    "eject": "react-scripts eject",
    "test": "react-scripts test",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "electron-updater": "^6.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.0.0",
    "react-scripts": "5.0.1",
    "typescript": "~4.9.5",
    "wait-on": "^7.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.microsoft.fru-selector",
    "productName": "Surface FRU Selector",
    "files": [
      "dist/main/**/*",
      "build/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "DJPanic",
      "repo": "FRUSelector-v2"
    }
  }
}
